  // Edebi Akım Bilgileri — Konu anlatımı
  { id: "f051", subject: "Edebiyat", topic: "Edebi Akımlar", type: "flashcard", front: "Klasisizm nedir?", back: "Akıl ve mantık ön planda, kural koyucu, Antik Yunan ve Roma örnek alınır. Türk edebiyatında karşılığı yoktur.", difficulty: 2, source: "seed", tags: ["akım","konu"] },
  { id: "f052", subject: "Edebiyat", topic: "Edebi Akımlar", type: "flashcard", front: "Romantizm nedir?", back: "Duygu ve hayal ön planda, tabiat sevgisi, milli tarih ilgisi. Tanzimat I. döneme etki etmiştir.", difficulty: 2, source: "seed", tags: ["akım","konu"] },
  { id: "f053", subject: "Edebiyat", topic: "Edebi Akımlar", type: "flashcard", front: "Realizm nedir?", back: "Gerçekçilik, toplumsal sorunlar, nesnel bakış. Tanzimat II. ve Servet-i Fünun dönemine egemendir.", difficulty: 2, source: "seed", tags: ["akım","konu"] },
  { id: "f054", subject: "Edebiyat", topic: "Edebi Akımlar", type: "flashcard", front: "Natüralizm nedir?", back: "Realizmin aşırı biçimi; kalıtım ve çevre belirleyicidir. Temsilcisi: Nabizade Nazım (Karabibik).", difficulty: 2, source: "seed", tags: ["akım","konu"] },
  { id: "f055", subject: "Edebiyat", topic: "Edebi Akımlar", type: "flashcard", front: "Sembolizm nedir?", back: "Anlam kapalıdır, müzikalite ön planda, iç dünya yansıtılır. Ahmet Haşim en önemli temsilcisidir.", difficulty: 2, source: "seed", tags: ["akım","konu"] },
  { id: "f056", subject: "Edebiyat", topic: "Edebi Akımlar", type: "flashcard", front: "Parnasizm nedir?", back: "Sanat sanat içindir, biçim mükemmelliği. Cenap Şahabettin ilk parnasist şiiri (Elhan-ı Şita) yazmıştır.", difficulty: 2, source: "seed", tags: ["akım","konu"] },

