  // Tanzimat I — çeşitli soru tipleri
  { id: "q001", subject: "Edebiyat", topic: "Tanzimat I. Dönem", type: "quiz", question: "Türk edebiyatının ilk yerli tiyatrosu hangisidir?", options: ["Şair Evlenmesi", "Vatan Yahut Silistre", "İntibah", "Cezmi"], answer: "Şair Evlenmesi", difficulty: 1, source: "seed", tags: ["tiyatro","ilk","tanzimat"] },
  { id: "q002", subject: "Edebiyat", topic: "Tanzimat I. Dönem", type: "quiz", question: "Aşağıdakilerden hangisi Namık Kemal'e ait bir eser değildir?", options: ["Araba Sevdası", "İntibah", "Cezmi", "Vatan Yahut Silistre"], answer: "Araba Sevdası", difficulty: 2, source: "seed", tags: ["tanzimat","namık kemal"] },
  { id: "q003", subject: "Edebiyat", topic: "Tanzimat I. Dönem", type: "quiz", question: "\"Taaşşuk-ı Talat ve Fitnat\" kimin kaleme aldığı eserdir?", options: ["Şemsettin Sami", "Ahmet Mithat Efendi", "Namık Kemal", "Ziya Paşa"], answer: "Şemsettin Sami", difficulty: 2, source: "seed", tags: ["roman","ilk","tanzimat"] },
  { id: "q004", subject: "Edebiyat", topic: "Tanzimat I. Dönem", type: "quiz", question: "Tanzimat I. dönem sanatçıları hangi edebi akımdan etkilenmiştir?", options: ["Romantizm", "Realizm", "Sembolizm", "Parnasizm"], answer: "Romantizm", difficulty: 2, source: "seed", tags: ["akım","tanzimat"] },
  { id: "q005", subject: "Edebiyat", topic: "Tanzimat I. Dönem", type: "quiz", question: "Namık Kemal'in roman türündeki ilk eseri hangisidir?", options: ["İntibah", "Cezmi", "Vatan Yahut Silistre", "Şair Evlenmesi"], answer: "İntibah", difficulty: 2, source: "seed", tags: ["roman","tanzimat","namık kemal"] },

  // Tanzimat II
  { id: "q006", subject: "Edebiyat", topic: "Tanzimat II. Dönem", type: "quiz", question: "Batılılaşmanın yanlış uygulandığını eleştiren \"Araba Sevdası\" romanının yazarı kimdir?", options: ["Recaizade Mahmut Ekrem", "Samipaşazade Sezai", "Abdülhak Hamit", "Muallim Naci"], answer: "Recaizade Mahmut Ekrem", difficulty: 2, source: "seed", tags: ["roman","tanzimat"] },
  { id: "q007", subject: "Edebiyat", topic: "Tanzimat II. Dönem", type: "quiz", question: "Aşağıdakilerden hangisi Abdülhak Hamit Tarhan'a ait bir eserdir?", options: ["Makber", "Sergüzeşt", "Karabibik", "Zemzeme"], answer: "Makber", difficulty: 2, source: "seed", tags: ["şiir","tanzimat"] },
  { id: "q008", subject: "Edebiyat", topic: "Tanzimat II. Dönem", type: "quiz", question: "Köle ticaretini konu alan \"Sergüzeşt\" romanı kime aittir?", options: ["Samipaşazade Sezai", "Recaizade Mahmut Ekrem", "Nabizade Nazım", "Muallim Naci"], answer: "Samipaşazade Sezai", difficulty: 2, source: "seed", tags: ["roman","tanzimat"] },
  { id: "q009", subject: "Edebiyat", topic: "Tanzimat II. Dönem", type: "quiz", question: "\"Karabibik\" ve \"Zehra\" hangi yazara aittir?", options: ["Nabizade Nazım", "Samipaşazade Sezai", "Recaizade Mahmut Ekrem", "Muallim Naci"], answer: "Nabizade Nazım", difficulty: 2, source: "seed", tags: ["roman","tanzimat","natüralizm"] },

  // Servet-i Fünun
  { id: "q010", subject: "Edebiyat", topic: "Servet-i Fünun", type: "quiz", question: "Servet-i Fünun döneminin nesirdeki (roman) en güçlü ismi kimdir?", options: ["Halit Ziya Uşaklıgil", "Tevfik Fikret", "Cenap Şahabettin", "Mehmet Rauf"], answer: "Halit Ziya Uşaklıgil", difficulty: 1, source: "seed", tags: ["servetifunun","roman"] },
  { id: "q011", subject: "Edebiyat", topic: "Servet-i Fünun", type: "quiz", question: "Aşağıdakilerden hangisi Tevfik Fikret'e ait değildir?", options: ["Hac Yolunda", "Rubab-ı Şikeste", "Haluk'un Defteri", "Şermin"], answer: "Hac Yolunda", difficulty: 2, source: "seed", tags: ["servetifunun","şiir"] },
  { id: "q012", subject: "Edebiyat", topic: "Servet-i Fünun", type: "quiz", question: "Türk edebiyatında parnasizmin ilk örneği hangi şairle özdeşleşir?", options: ["Cenap Şahabettin", "Tevfik Fikret", "Halit Ziya", "Mehmet Rauf"], answer: "Cenap Şahabettin", difficulty: 2, source: "seed", tags: ["servetifunun","parnasizm"] },
  { id: "q013", subject: "Edebiyat", topic: "Servet-i Fünun", type: "quiz", question: "\"Eylül\" romanı Türk edebiyatındaki hangi özelliğiyle öne çıkar?", options: ["İlk psikolojik roman", "İlk köy romanı", "İlk tarihi roman", "İlk polisiye roman"], answer: "İlk psikolojik roman", difficulty: 2, source: "seed", tags: ["servetifunun","roman","ilk"] },
  { id: "q014", subject: "Edebiyat", topic: "Servet-i Fünun", type: "quiz", question: "\"Kırık Hayatlar\" ve \"Mai ve Siyah\" hangi yazara aittir?", options: ["Halit Ziya Uşaklıgil", "Mehmet Rauf", "Hüseyin Cahit Yalçın", "Süleyman Nazif"], answer: "Halit Ziya Uşaklıgil", difficulty: 1, source: "seed", tags: ["servetifunun","roman"] },

  // Fecr-i Ati
  { id: "q015", subject: "Edebiyat", topic: "Fecr-i Ati", type: "quiz", question: "Sembolizmin Türk şiirindeki en güçlü temsilcisi kimdir?", options: ["Ahmet Haşim", "Yahya Kemal", "Tevfik Fikret", "Mehmet Akif"], answer: "Ahmet Haşim", difficulty: 1, source: "seed", tags: ["fecriati","sembolizm"] },
  { id: "q016", subject: "Edebiyat", topic: "Fecr-i Ati", type: "quiz", question: "Ahmet Haşim'in şiir kitapları arasında hangisi yer almaz?", options: ["Gurabahane-i Laklakan", "Göl Saatleri", "Piyale", "Elhan-ı Şita"], answer: "Elhan-ı Şita", difficulty: 3, source: "seed", tags: ["fecriati","ahmet haşim"] },
