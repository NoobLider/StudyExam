  // ═══════════════════════════════════════════════
  // CUMHURİYET DÖNEMİ EDEBİYATI — FLASHCARD KONU ANLATIMI
  // ═══════════════════════════════════════════════

  // Genel özellikler
  { id: "cfd001", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Genel", type: "flashcard", front: "Cumhuriyet Dönemi edebiyatının başlangıç tarihi nedir?", back: "1923 — Türkiye Cumhuriyeti'nin ilanıyla başlar. Milli Edebiyat'tan devralınan dil sadeleşmesi ve halkçılık devam eder.", difficulty: 1, source: "seed", tags: ["cumhuriyet","genel"] },
  { id: "cfd002", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Genel", type: "flashcard", front: "Cumhuriyet Dönemi edebiyatının temel özellikleri nelerdir?", back: "1) Sade Türkçe  2) Halkçılık ve toplumcu içerik  3) Anadolu coğrafyası  4) Köy edebiyatı  5) Bireysel psikoloji  6) Sosyal sorunlar (köylü, işçi, kadın)", difficulty: 2, source: "seed", tags: ["cumhuriyet","genel"] },

  // Garip Akımı
  { id: "cfd003", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Garip Akımı", type: "flashcard", front: "Garip akımı nedir ve ne zaman ortaya çıkmıştır?", back: "1941'de Orhan Veli, Melih Cevdet Anday ve Oktay Rifat'ın yayımladığı 'Garip' adlı şiir kitabıyla başlar. Ölçü, kafiye, süslü dili reddeder; sokaktaki insanı, gündelik hayatı şiire taşır.", difficulty: 1, source: "seed", tags: ["cumhuriyet","garip","akım"] },
  { id: "cfd004", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Garip Akımı", type: "flashcard", front: "Garip akımının temel ilkeleri nelerdir?", back: "• Vezin ve kafiye yoktur  • Söz sanatlarından kaçınılır  • Sıradan insan ve gündelik yaşam işlenir  • Şiirde öyküleme ve mizah  • 'Sanat toplum içindir' yerine bireysel duyarlılık", difficulty: 2, source: "seed", tags: ["cumhuriyet","garip"] },
  { id: "cfd005", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Garip Akımı", type: "flashcard", front: "Orhan Veli Kanık'ın en önemli eserleri", back: "Garip (1941, manifesto), Vazgeçemiyorum, Destan Gibi, Yenisi, Nasreddin Hoca Hikayeleri (çeviri). 'Kitabe-i Seng-i Mezar', 'Anlatamıyorum' ünlü şiirleri.", difficulty: 1, source: "seed", tags: ["cumhuriyet","garip","orhan veli"] },
  { id: "cfd006", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Garip Akımı", type: "flashcard", front: "Melih Cevdet Anday'ın Garip sonrası gelişimi", back: "Garip'ten ayrılarak mitolojik ve felsefi şiire yönelir. Eserleri: Rahatı Kaçan Ağaç, Kolları Bağlı Odysseus, Yanyana, Teknenin Ölümü. 'Troya Önünde Atlar' en önemli şiiri.", difficulty: 2, source: "seed", tags: ["cumhuriyet","garip","melih cevdet"] },
  { id: "cfd007", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Garip Akımı", type: "flashcard", front: "Oktay Rifat'ın şiir anlayışı", back: "Garip'ten sonra İkinci Yeni'ye yaklaşır. Eserleri: Garip, Yaşayıp Ölmek Aşk ile Güneşte, Aşık Merdiveni, Karga ile Tilki, Şiir Kitabı.", difficulty: 2, source: "seed", tags: ["cumhuriyet","garip","oktay rifat"] },

  // İkinci Yeni
  { id: "cfd008", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "İkinci Yeni", type: "flashcard", front: "İkinci Yeni akımı nedir?", back: "1950'lerin ortasında ortaya çıkan şiir akımı. Garip'in sadeliğine tepki olarak anlam kapalılığı, soyut imgeler, bilinçaltı, dil deneyi ön plana çıkar. Sürrealizm etkisi görülür.", difficulty: 1, source: "seed", tags: ["cumhuriyet","ikinciyeni","akım"] },
  { id: "cfd009", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "İkinci Yeni", type: "flashcard", front: "İkinci Yeni'nin başlıca temsilcileri ve eserleri", back: "• Cemal Süreya — Üvercinka, Sevda Sözleri\n• İlhan Berk — Galile Denizi, Köroğlu\n• Turgut Uyar — Arz-ı Hal, Divan\n• Edip Cansever — Petrol, Yerçekimli Karanfil\n• Ece Ayhan — Kınar Hanımın Denizleri\n• Sezai Karakoç — Hızırla Kırk Saat", difficulty: 2, source: "seed", tags: ["cumhuriyet","ikinciyeni"] },
  { id: "cfd010", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "İkinci Yeni", type: "flashcard", front: "Cemal Süreya'nın şiir anlayışı ve eserleri", back: "Erotizm ve toplumsal eleştiriyi birleştirir. 'Folklor Şiire Düşman' makalesiyle İkinci Yeni'yi savunur. Eserleri: Üvercinka, Sevda Sözleri, Güz Bitiği, Uçurumda Açan.", difficulty: 2, source: "seed", tags: ["cumhuriyet","ikinciyeni","cemal süreya"] },
  { id: "cfd011", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "İkinci Yeni", type: "flashcard", front: "Sezai Karakoç'un şiiri ve İslamcı duruşu", back: "Metafizik ve İslam medeniyeti değerleri üzerine inşa edilmiş şiir. Diriliş dergisini çıkarmıştır. Eserleri: Hızırla Kırk Saat, Körfez, Şahdamar, Sesler.", difficulty: 2, source: "seed", tags: ["cumhuriyet","ikinciyeni","sezai karakoç"] },

  // Toplumcu Gerçekçilik
  { id: "cfd012", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Toplumcu Gerçekçilik", type: "flashcard", front: "Toplumcu Gerçekçilik akımı nedir?", back: "Marksist ideoloji etkisiyle işçi, köylü ve ezilenlerin sorunlarını gerçekçi biçimde anlatan edebiyat. Nazım Hikmet öncüsüdür. 1930'lardan itibaren güçlenir.", difficulty: 1, source: "seed", tags: ["cumhuriyet","toplumcu","akım"] },
  { id: "cfd013", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Toplumcu Gerçekçilik", type: "flashcard", front: "Nazım Hikmet Ran — hayatı ve önemi", back: "1902–1963. Türk şiirini kırdığı için 'şiirimizin Atatürk'ü' sayılır. Serbest nazım ve toplumcu şiiri Türk edebiyatına taşır. 17 yıl hapis yattı, 1951'de Sovyetler'e kaçtı.", difficulty: 1, source: "seed", tags: ["cumhuriyet","nazım hikmet"] },
  { id: "cfd014", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Toplumcu Gerçekçilik", type: "flashcard", front: "Nazım Hikmet Ran'ın başlıca eserleri", back: "Şiir: Kuvayı Milliye, Memleketimden İnsan Manzaraları (başyapıt), Şeyh Bedrettin Destanı, 835 Satır, Jokond ile Si-Ya-U\nTiyatro: Kafatası, İvan İvanoviç\nRoman: Yaşamak Güzel Şey Be Kardeşim", difficulty: 1, source: "seed", tags: ["cumhuriyet","nazım hikmet"] },
  { id: "cfd015", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Toplumcu Gerçekçilik", type: "flashcard", front: "Sabahattin Ali — hayatı ve önemi", back: "1907–1948. Toplumcu gerçekçi roman ve hikâyenin ustası. Köylü ve ezilenlerin sesi. 'Kürk Mantolu Madonna' modern Türk romanının şaheseri sayılır. Şüpheli koşullarda öldürüldü.", difficulty: 1, source: "seed", tags: ["cumhuriyet","sabahattin ali"] },
  { id: "cfd016", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Toplumcu Gerçekçilik", type: "flashcard", front: "Sabahattin Ali'nin başlıca eserleri", back: "Roman: Kürk Mantolu Madonna, Kuyucaklı Yusuf, İçimizdeki Şeytan\nHikâye: Değirmen, Ses, Sırça Köşk, Yeni Dünya\nŞiir: Dağlar ve Rüzgar", difficulty: 1, source: "seed", tags: ["cumhuriyet","sabahattin ali"] },

  // Köy Edebiyatı
  { id: "cfd017", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Köy Edebiyatı", type: "flashcard", front: "Köy Edebiyatı nedir ve ne zaman güçlenmiştir?", back: "1950 sonrası Anadolu köyünü, köylünün sorunlarını (toprak, ağa baskısı, yoksulluk) gerçekçi biçimde anlatan edebiyat. Köy Enstitüsü mezunları bu akımın temel taşıdır.", difficulty: 1, source: "seed", tags: ["cumhuriyet","köy edebiyatı"] },
  { id: "cfd018", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Köy Edebiyatı", type: "flashcard", front: "Yaşar Kemal — hayatı ve önemi", back: "1923–2015. Türk edebiyatının uluslararası alanda en çok tanınan yazarı. Nobel'e defalarca aday gösterildi. Epik gerçekçilik, güçlü masal dili ve Çukurova coğrafyası belirgindir.", difficulty: 1, source: "seed", tags: ["cumhuriyet","yaşar kemal"] },
  { id: "cfd019", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Köy Edebiyatı", type: "flashcard", front: "Yaşar Kemal'in başlıca eserleri", back: "İnce Memed (4 cilt), Memed Bey, Yer Demir Gök Bakır, Ortadirek, Üç Anadolu Efsanesi, Yılanı Öldürseler, Fırat Suyu Kan Akıyor Baksana, Al Gözüm Seyreyle Salih", difficulty: 1, source: "seed", tags: ["cumhuriyet","yaşar kemal"] },
  { id: "cfd020", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Köy Edebiyatı", type: "flashcard", front: "Fakir Baykurt — hayatı ve eserleri", back: "1929–1999. Köy Enstitüsü mezunu öğretmen-yazar. Ağa baskısını ve köy sorunlarını anlatır. Eserleri: Yılanların Öcü, Tırpan, Irazca'nın Dirliği, Onuncu Köy, Kara Ahmet Destanı.", difficulty: 2, source: "seed", tags: ["cumhuriyet","fakir baykurt","köy edebiyatı"] },
  { id: "cfd021", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Köy Edebiyatı", type: "flashcard", front: "Orhan Kemal — hayatı ve eserleri", back: "1914–1970. İşçi sınıfı ve kentli yoksulları anlatır. Çukurova ve fabrika işçileri teması. Eserleri: Bereketli Topraklar Üzerinde, Murtaza, Cemile, Hanımın Çiftliği, Baba Evi.", difficulty: 2, source: "seed", tags: ["cumhuriyet","orhan kemal"] },
  { id: "cfd022", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Köy Edebiyatı", type: "flashcard", front: "Kemal Tahir — hayatı ve eserleri", back: "1910–1973. Tarih romanları ve sosyalist gerçekçilik. Osmanlı ve kurtuluş dönemi romanları. Eserleri: Devlet Ana, Yorgun Savaşçı, Kurt Kanunu, Esir Şehrin İnsanları, Rahmet Yolları Kesti.", difficulty: 2, source: "seed", tags: ["cumhuriyet","kemal tahir"] },

  // Varoluşçu / Bireysel Şiir
  { id: "cfd023", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Bireysel Şiir", type: "flashcard", front: "Ahmet Hamdi Tanpınar — şiir ve roman anlayışı", back: "Doğu-Batı sentezi, zaman-bilinç-hafıza temaları. Bergson felsefesinden etkilenir. Roman: Huzur, Saatleri Ayarlama Enstitüsü, Mahur Beste. Şiir: Bütün Şiirleri. Deneme: Beş Şehir.", difficulty: 1, source: "seed", tags: ["cumhuriyet","tanpınar"] },
  { id: "cfd024", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Bireysel Şiir", type: "flashcard", front: "Cahit Sıtkı Tarancı — şiir anlayışı ve eserleri", back: "Ölüm, yalnızlık ve hayatın geçiciliği temaları. Saf/öz şiir anlayışı. 'Otuz Beş Yaş' en ünlü şiiri. Eserleri: Ömrümde Sükut, Düşten Güzel, Sonrası, Bütün Şiirleri.", difficulty: 2, source: "seed", tags: ["cumhuriyet","cahit sıtkı"] },
  { id: "cfd025", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Bireysel Şiir", type: "flashcard", front: "Necip Fazıl Kısakürek — şiir ve dünya görüşü", back: "Varoluşçu kaygı, İslami mistisizm. 'Kaldırımlar' ve 'Çile' en bilinen şiirleri. Büyük Doğu dergisini çıkardı. Eserleri: Örümcek Ağı, Kaldırımlar, Çile (tüm şiirleri), Tiyatro: Reis Bey, Bir Adam Yaratmak.", difficulty: 2, source: "seed", tags: ["cumhuriyet","necip fazıl"] },
  { id: "cfd026", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Bireysel Şiir", type: "flashcard", front: "Behçet Necatigil — şiir anlayışı ve eserleri", back: "Orta sınıf insanın sıkışmışlığını, aile ve ev içi dünyayı işler. Yoğun imgeler. Eserleri: Kapalı Çarşı, Evler, Eski Toprak, Divançe, Zebra, Dar Çağ.", difficulty: 2, source: "seed", tags: ["cumhuriyet","necatigil"] },

  // Cumhuriyet Romanı Genel
  { id: "cfd027", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Roman", type: "flashcard", front: "Orhan Pamuk — Nobel ödülü ve önemi", back: "2006 Nobel Edebiyat Ödülü. Türk ve İslam kültürünün Batı'yla çatışması, kimlik ve hafıza temaları. Postmodern teknikler.", difficulty: 1, source: "seed", tags: ["cumhuriyet","orhan pamuk"] },
  { id: "cfd028", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Roman", type: "flashcard", front: "Orhan Pamuk'un başlıca eserleri", back: "Cevdet Bey ve Oğulları, Sessiz Ev, Beyaz Kale, Kara Kitap, Yeni Hayat, Benim Adım Kırmızı (2000, IMPAC Ödülü), Kar, İstanbul, Masumiyet Müzesi, Kafamda Bir Tuhaflık", difficulty: 1, source: "seed", tags: ["cumhuriyet","orhan pamuk"] },
  { id: "cfd029", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Roman", type: "flashcard", front: "Sait Faik Abasıyanık — hikâye anlayışı", back: "Boğaz ve balıkçı semtleri, küçük insanlar, varoluş kaygısı. Kısa hikâye ustası. Eserleri: Semaver, Sarnıç, Şahmerdan, Havada Bulut, Son Kuşlar, Alemdağ'da Var Bir Yılan.", difficulty: 1, source: "seed", tags: ["cumhuriyet","sait faik"] },
  { id: "cfd030", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Roman", type: "flashcard", front: "Adalet Ağaoğlu — romanları ve önemi", back: "Bireysel psikoloji ve toplumsal değişim. Ölmeye Yatmak, Bir Düğün Gecesi, Hayır (Dar Zamanlar üçlemesi). Fikrimin İnce Gülü, Ruh Üşümesi.", difficulty: 2, source: "seed", tags: ["cumhuriyet","adalet ağaoğlu"] },
  { id: "cfd031", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Roman", type: "flashcard", front: "Çağdaş Türk hikâyeciliğinde Sait Faik'in yeri", back: "Modern Türk hikâyeciliğinin kurucusu sayılır. Her yıl onun adına 'Sait Faik Hikâye Ödülü' verilir. Realizm ve lirizmri birleştirir, olay değil atmosfer önemlidir.", difficulty: 2, source: "seed", tags: ["cumhuriyet","sait faik"] },
  { id: "cfd032", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Roman", type: "flashcard", front: "Peyami Safa — roman anlayışı ve eserleri", back: "Doğu-Batı çatışması, ruhsal bunalım. Eserleri: Dokuzuncu Hariciye Koğuşu (otobiyografik), Fatih-Harbiye, Matmazel Noraliya'nın Koltuğu, Sözde Kızlar. Mizahi: Server Bedi takma adı.", difficulty: 2, source: "seed", tags: ["cumhuriyet","peyami safa"] },
  { id: "cfd033", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Roman", type: "flashcard", front: "Halide Edip Adıvar'ın Cumhuriyet dönemi eserleri", back: "Sinekli Bakkal (en olgun yapıtı), Tatarcık, Akile Hanım Sokağı, Sonsuz Panayır. ABD'de ders verdi, Milli Mücadele'yi anlattı (Türkün Ateşle İmtihanı).", difficulty: 2, source: "seed", tags: ["cumhuriyet","halide edip"] },

  // Cumhuriyet Tiyatrosu
  { id: "cfd034", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Tiyatro", type: "flashcard", front: "Haldun Taner — tiyatro anlayışı ve eserleri", back: "Epik tiyatro ve kabare tiyatrosunu Türkiye'ye tanıttı. Eserleri: Keşanlı Ali Destanı, Gözlerimi Kaparım Vazifemi Yaparım, Dışarıdaki Adam, Sersem Kocanın Kurnaz Karısı.", difficulty: 2, source: "seed", tags: ["cumhuriyet","haldun taner","tiyatro"] },
  { id: "cfd035", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Tiyatro", type: "flashcard", front: "Güngör Dilmen — tiyatro anlayışı ve eserleri", back: "Mitoloji ve Anadolu kaynaklı tiyatro. Eserleri: Midas'ın Kulakları, Midas'ın Altınları, Ben Anadolu, Kurban, Cengiz Han'ın Bisikletçisi.", difficulty: 3, source: "seed", tags: ["cumhuriyet","güngör dilmen","tiyatro"] },
  { id: "cfd036", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Tiyatro", type: "flashcard", front: "Necip Fazıl Kısakürek'in tiyatroları", back: "Reis Bey, Bir Adam Yaratmak, Sabır Taşı, Para, Ahşap Konak. 'Bir Adam Yaratmak' Türk tiyatrosunun varoluşçu başyapıtı sayılır.", difficulty: 2, source: "seed", tags: ["cumhuriyet","necip fazıl","tiyatro"] },

  // Hikayeleri
  { id: "cfd037", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Hikâye", type: "flashcard", front: "Hüseyin Rahmi Gürpınar'ın Cumhuriyet dönemindeki rolü", back: "Tanzimat'tan Cumhuriyet'e geçen köprü yazar. İstanbul halkını ve Batılılaşmayı eleştirir. Mizahi gerçekçilik. Ölümü: 1944. Son eserleri: Kokotlar Mektebi, Utanmaz Adam.", difficulty: 2, source: "seed", tags: ["cumhuriyet","hüseyin rahmi"] },
  { id: "cfd038", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Hikâye", type: "flashcard", front: "Tarık Buğra — roman anlayışı ve eserleri", back: "Tarihi roman ve milliyetçi duyarlılık. Eserleri: Küçük Ağa, İbişin Rüyası, Osmancık, Firavun İmanı, Dönemeçte.", difficulty: 2, source: "seed", tags: ["cumhuriyet","tarık buğra"] },

  // Döneme ait kavramlar
  { id: "cfd039", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Kavramlar", type: "flashcard", front: "Köy Enstitüleri ve edebiyata katkısı", back: "1940–1954 yılları arasında faaliyet gösteren, köy çocuklarını öğretmen olarak yetiştiren kurumlar. Fakir Baykurt, Mahmut Makal, Talip Apaydın gibi yazarlar bu kurumlardan çıktı.", difficulty: 2, source: "seed", tags: ["cumhuriyet","köy enstitüsü"] },
  { id: "cfd040", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Kavramlar", type: "flashcard", front: "Benim Adım Kırmızı neden önemlidir?", back: "Orhan Pamuk'un 2000 tarihli romanı. 16. yy Osmanlı minyatür sanatçıları üzerinden Doğu-Batı görme biçimlerini sorgular. Cinayeti merkeze alır. IMPAC Dublin Ödülü kazandı.", difficulty: 2, source: "seed", tags: ["cumhuriyet","orhan pamuk"] },
  { id: "cfd041", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Kavramlar", type: "flashcard", front: "Memleketimden İnsan Manzaraları neden başyapıttır?", back: "Nazım Hikmet'in 15.000 dizelik epik şiiri (1939–1945). Anadolu insanının yaşamını panoramik biçimde anlatır. Tren yolculuğu iskeleti üzerine kurulu. Türk şiirinin en kapsamlı eseri.", difficulty: 2, source: "seed", tags: ["cumhuriyet","nazım hikmet"] },
  { id: "cfd042", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Kavramlar", type: "flashcard", front: "Dokuzuncu Hariciye Koğuşu neden önemlidir?", back: "Peyami Safa'nın otobiyografik romanı (1930). Kemik tüberkülozu hastası gencin hastane ve iç dünyasını anlatır. Psikolojik roman türünün Cumhuriyet dönemi örneği.", difficulty: 2, source: "seed", tags: ["cumhuriyet","peyami safa"] },
  { id: "cfd043", mode: "comprehensive" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Kavramlar", type: "flashcard", front: "Huzur romanı neden önemlidir?", back: "Ahmet Hamdi Tanpınar'ın 1949 tarihli romanı. İstanbul sevgisi, Doğu-Batı çatışması, zaman ve hafıza temaları. Türk romanının en entelektüel eseri sayılır.", difficulty: 2, source: "seed", tags: ["cumhuriyet","tanpınar"] },

