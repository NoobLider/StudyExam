  // Milli Edebiyat
  { id: "q018", subject: "Edebiyat", topic: "Milli Edebiyat", type: "quiz", question: "Aşağıdakilerden hangisi Reşat Nuri Güntekin'e ait bir eser değildir?", options: ["Sinekli Bakkal", "Çalıkuşu", "Yaprak Dökümü", "Yeşil Gece"], answer: "Sinekli Bakkal", difficulty: 2, source: "seed", tags: ["milliedebiyat","roman"] },
  { id: "q019", subject: "Edebiyat", topic: "Milli Edebiyat", type: "quiz", question: "Anadolu'nun kurtuluş mücadelesini bir öğretmenin gözünden anlatan roman hangisidir?", options: ["Çalıkuşu", "Ateşten Gömlek", "Yaban", "Kiralık Konak"], answer: "Çalıkuşu", difficulty: 2, source: "seed", tags: ["milliedebiyat","roman"] },
  { id: "q020", subject: "Edebiyat", topic: "Milli Edebiyat", type: "quiz", question: "\"Yaban\" romanının yazarı kimdir?", options: ["Yakup Kadri Karaosmanoğlu", "Refik Halit Karay", "Halide Edip Adıvar", "Reşat Nuri Güntekin"], answer: "Yakup Kadri Karaosmanoğlu", difficulty: 1, source: "seed", tags: ["milliedebiyat","roman"] },
  { id: "q021", subject: "Edebiyat", topic: "Milli Edebiyat", type: "quiz", question: "Ömer Seyfettin'e ait olan hikâye hangisidir?", options: ["Pembe İncili Kaftan", "Memleket Hikâyeleri", "Gülüp Ağladıklarım", "Küçük Şeyler"], answer: "Pembe İncili Kaftan", difficulty: 1, source: "seed", tags: ["milliedebiyat","hikâye"] },
  { id: "q022", subject: "Edebiyat", topic: "Milli Edebiyat", type: "quiz", question: "\"Memleket Hikâyeleri\" ve \"Gurbet Hikâyeleri\" hangi yazara aittir?", options: ["Refik Halit Karay", "Ömer Seyfettin", "Yakup Kadri", "Reşat Nuri"], answer: "Refik Halit Karay", difficulty: 2, source: "seed", tags: ["milliedebiyat","hikâye"] },
  { id: "q023", subject: "Edebiyat", topic: "Milli Edebiyat", type: "quiz", question: "\"Handan\" ve \"Sinekli Bakkal\" hangi yazara aittir?", options: ["Halide Edip Adıvar", "Reşat Nuri Güntekin", "Refik Halit Karay", "Yakup Kadri"], answer: "Halide Edip Adıvar", difficulty: 1, source: "seed", tags: ["milliedebiyat","roman"] },
  { id: "q024", subject: "Edebiyat", topic: "Milli Edebiyat", type: "quiz", question: "Mehmet Akif Ersoy'un tüm şiirlerini kapsayan yedi kitaplık eseri hangisidir?", options: ["Safahat", "Kızıl Elma", "Türk Sazı", "Tan Sesleri"], answer: "Safahat", difficulty: 1, source: "seed", tags: ["milliedebiyat","şiir"] },
  { id: "q025", subject: "Edebiyat", topic: "Milli Edebiyat", type: "quiz", question: "\"Kiralık Konak\" ve \"Nur Baba\" hangi yazara aittir?", options: ["Yakup Kadri Karaosmanoğlu", "Refik Halit Karay", "Reşat Nuri Güntekin", "Halide Edip"], answer: "Yakup Kadri Karaosmanoğlu", difficulty: 2, source: "seed", tags: ["milliedebiyat","roman"] },

  // Cumhuriyet Dönemi
  { id: "q026", mode: "both" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", type: "quiz", question: "Garip akımının üç kurucusundan biri olmayan şair kimdir?", options: ["Cahit Sıtkı Tarancı", "Orhan Veli Kanık", "Melih Cevdet Anday", "Oktay Rifat"], answer: "Cahit Sıtkı Tarancı", difficulty: 2, source: "seed", tags: ["cumhuriyet","garip"] },
  { id: "q027", mode: "both" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", type: "quiz", question: "\"Kürk Mantolu Madonna\" ve \"İçimizdeki Şeytan\" hangi yazara aittir?", options: ["Sabahattin Ali", "Orhan Kemal", "Kemal Tahir", "Fakir Baykurt"], answer: "Sabahattin Ali", difficulty: 1, source: "seed", tags: ["cumhuriyet","roman"] },
  { id: "q028", mode: "both" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", type: "quiz", question: "\"İnce Memed\" ve \"Yer Demir Gök Bakır\" hangi yazara aittir?", options: ["Yaşar Kemal", "Orhan Kemal", "Fakir Baykurt", "Kemal Tahir"], answer: "Yaşar Kemal", difficulty: 1, source: "seed", tags: ["cumhuriyet","roman"] },
  { id: "q029", mode: "both" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", type: "quiz", question: "Nobel Edebiyat Ödülü'nü kazanan Türk yazar ve ödülü aldığı romanı hangi şıkta doğru eşleştirilmiştir?", options: ["Orhan Pamuk – Kar", "Yaşar Kemal – İnce Memed", "Nazım Hikmet – Kuvayı Milliye", "Ahmet Hamdi Tanpınar – Huzur"], answer: "Orhan Pamuk – Kar", difficulty: 2, source: "seed", tags: ["cumhuriyet","ödül"] },
  { id: "q030", mode: "both" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", type: "quiz", question: "\"Huzur\" ve \"Saatleri Ayarlama Enstitüsü\" hangi yazara aittir?", options: ["Ahmet Hamdi Tanpınar", "Orhan Pamuk", "Kemal Tahir", "Sabahattin Ali"], answer: "Ahmet Hamdi Tanpınar", difficulty: 2, source: "seed", tags: ["cumhuriyet","roman"] },
  { id: "q031", mode: "both" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", type: "quiz", question: "\"Kuvayı Milliye\" ve \"Memleketimden İnsan Manzaraları\" hangi şaire aittir?", options: ["Nazım Hikmet Ran", "Mehmet Akif Ersoy", "Orhan Veli Kanık", "Cahit Sıtkı Tarancı"], answer: "Nazım Hikmet Ran", difficulty: 1, source: "seed", tags: ["cumhuriyet","şiir"] },
  { id: "q032", mode: "both" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", type: "quiz", question: "İkinci Yeni şiir akımı hangi özelliğiyle Garip'ten ayrılır?", options: ["Anlam kapalılığı ve soyut imgeler", "Sade dil ve sokaktaki insanı anlatma", "Hece ölçüsünü benimseme", "Divan geleneğine dönüş"], answer: "Anlam kapalılığı ve soyut imgeler", difficulty: 2, source: "seed", tags: ["cumhuriyet","ikinciyeni","akım"] },
  { id: "q033", mode: "both" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", type: "quiz", question: "\"Devlet Ana\" hangi yazarın tarihî romanıdır?", options: ["Kemal Tahir", "Orhan Kemal", "Yaşar Kemal", "Fakir Baykurt"], answer: "Kemal Tahir", difficulty: 2, source: "seed", tags: ["cumhuriyet","roman"] },
  { id: "q034", mode: "both" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", type: "quiz", question: "\"Yılanların Öcü\" ve \"Tırpan\" hangi yazara aittir?", options: ["Fakir Baykurt", "Orhan Kemal", "Yaşar Kemal", "Kemal Tahir"], answer: "Fakir Baykurt", difficulty: 2, source: "seed", tags: ["cumhuriyet","roman"] },
  { id: "q035", mode: "both" as const,, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", type: "quiz", question: "\"Murtaza\" ve \"Bereketli Topraklar Üzerinde\" hangi yazara aittir?", options: ["Orhan Kemal", "Yaşar Kemal", "Sabahattin Ali", "Kemal Tahir"], answer: "Orhan Kemal", difficulty: 2, source: "seed", tags: ["cumhuriyet","roman"] },

  // Divan Edebiyatı
  { id: "q036", subject: "Edebiyat", topic: "Divan Edebiyatı", type: "quiz", question: "\"Su Kasidesi\" ve \"Leyla ile Mecnun\" hangi divan şairine aittir?", options: ["Fuzuli", "Baki", "Nabi", "Şeyh Galip"], answer: "Fuzuli", difficulty: 1, source: "seed", tags: ["divan","şiir"] },
  { id: "q037", subject: "Edebiyat", topic: "Divan Edebiyatı", type: "quiz", question: "\"Hüsn-ü Aşk\" hangi yüzyılda, hangi şair tarafından yazılmıştır?", options: ["18. yy – Şeyh Galip", "16. yy – Fuzuli", "17. yy – Nabi", "15. yy – Şeyhi"], answer: "18. yy – Şeyh Galip", difficulty: 2, source: "seed", tags: ["divan","şiir"] },
  { id: "q038", subject: "Edebiyat", topic: "Divan Edebiyatı", type: "quiz", question: "\"Hayriyye\" ve \"Hayrabat\" hangi divan şairine aittir?", options: ["Nabi", "Baki", "Şeyh Galip", "Fuzuli"], answer: "Nabi", difficulty: 2, source: "seed", tags: ["divan","şiir"] },
  { id: "q039", subject: "Edebiyat", topic: "Divan Edebiyatı", type: "quiz", question: "Kutadgu Bilig'in yazarı kimdir ve hangi yüzyılda kaleme alınmıştır?", options: ["Yusuf Has Hacip – 11. yy", "Kaşgarlı Mahmut – 11. yy", "Ahmet Yesevi – 12. yy", "Edip Ahmet – 12. yy"], answer: "Yusuf Has Hacip – 11. yy", difficulty: 2, source: "seed", tags: ["divan","islami","ilk"] },
  { id: "q040", subject: "Edebiyat", topic: "Divan Edebiyatı", type: "quiz", question: "\"Divan-ı Lügat'it Türk\" hangi amaca hizmet etmek için yazılmıştır?", options: ["Türkçeyi Araplara öğretmek", "Osmanlı tarihini aktarmak", "Tasavvufu yaymak", "Devlet yönetimini öğretmek"], answer: "Türkçeyi Araplara öğretmek", difficulty: 2, source: "seed", tags: ["islami","dil"] },

  // Edebi akımlar
  { id: "q041", subject: "Edebiyat", topic: "Edebi Akımlar", type: "quiz", question: "\"Sanat toplum içindir\" anlayışını benimseyen akım hangisidir?", options: ["Realizm", "Klasisizm", "Parnasizm", "Sembolizm"], answer: "Realizm", difficulty: 2, source: "seed", tags: ["akım"] },
  { id: "q042", subject: "Edebiyat", topic: "Edebi Akımlar", type: "quiz", question: "Türk edebiyatında natüralizmin ilk temsilcisi ve eseri hangi şıkta doğru verilmiştir?", options: ["Nabizade Nazım – Karabibik", "Halit Ziya – Mai ve Siyah", "Mehmet Rauf – Eylül", "Recaizade – Araba Sevdası"], answer: "Nabizade Nazım – Karabibik", difficulty: 2, source: "seed", tags: ["akım","natüralizm"] },
  { id: "q043", subject: "Edebiyat", topic: "Edebi Akımlar", type: "quiz", question: "Romantizm akımının Türk edebiyatındaki en güçlü dönem temsilcileri hangi dönemde yetişmiştir?", options: ["Tanzimat I. Dönem", "Servet-i Fünun", "Milli Edebiyat", "Cumhuriyet Dönemi"], answer: "Tanzimat I. Dönem", difficulty: 2, source: "seed", tags: ["akım","romantizm","tanzimat"] },
  { id: "q044", subject: "Edebiyat", topic: "Edebi Akımlar", type: "quiz", question: "Parnasizm akımını benimseyen şairin temel kaygısı nedir?", options: ["Biçim mükemmelliği ve estetik", "Toplumsal fayda", "Duygusallık ve hayal", "Gerçekliğin birebir aktarımı"], answer: "Biçim mükemmelliği ve estetik", difficulty: 2, source: "seed", tags: ["akım","parnasizm"] },

  // Edebi Türler
  { id: "q045", subject: "Edebiyat", topic: "Edebi Türler", type: "quiz", question: "Divan edebiyatında kaç beyitten oluşan aşk ve şarap temalı nazım biçimine gazel denir?", options: ["5–15 beyit", "15–30 beyit", "3–5 beyit", "30–99 beyit"], answer: "5–15 beyit", difficulty: 2, source: "seed", tags: ["tür","divan"] },
  { id: "q046", subject: "Edebiyat", topic: "Edebi Türler", type: "quiz", question: "Divan edebiyatında büyük kişileri övmek için yazılan uzun nazım biçimi hangisidir?", options: ["Kaside", "Gazel", "Mesnevi", "Rubai"], answer: "Kaside", difficulty: 2, source: "seed", tags: ["tür","divan"] },
  { id: "q047", subject: "Edebiyat", topic: "Edebi Türler", type: "quiz", question: "Divan edebiyatında her beyiti kendi içinde kafiyeli, çift kafiye şemasıyla yazılan uzun manzume hangisidir?", options: ["Mesnevi", "Kaside", "Gazel", "Terkib-i bent"], answer: "Mesnevi", difficulty: 2, source: "seed", tags: ["tür","divan"] },
  { id: "q048", subject: "Edebiyat", topic: "Edebi Türler", type: "quiz", question: "Halk edebiyatında 11'li hece ölçüsüyle yazılan lirik nazım türü hangisidir?", options: ["Koşma", "Mani", "Destan", "Nefes"], answer: "Koşma", difficulty: 2, source: "seed", tags: ["tür","halk"] },
  { id: "q049", subject: "Edebiyat", topic: "Edebi Türler", type: "quiz", question: "7+7=14'lü hece ölçüsüyle söylenen anonim halk şiiri türü hangisidir?", options: ["Mani", "Koşma", "Semai", "Varsağı"], answer: "Mani", difficulty: 2, source: "seed", tags: ["tür","halk"] },
  { id: "q050", subject: "Edebiyat", topic: "Edebi Türler", type: "quiz", question: "Ölüm üzerine yazılan divan şiiri türü olan mersiyenin en bilinen örneği hangisidir?", options: ["Baki – Kanuni Mersiyesi", "Fuzuli – Su Kasidesi", "Nabi – Hayriyye", "Şeyh Galip – Hüsn-ü Aşk"], answer: "Baki – Kanuni Mersiyesi", difficulty: 2, source: "seed", tags: ["tür","divan","mersiye"] },

  // ═══════════════════════════════════════════════
  // SINAV ODAKLI VERİ SETİ (YILDIZLI) — mode: "exam"
  // ═══════════════════════════════════════════════

  // Hafıza Kartları — Kodlamalar
  { id: "ex001", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "flashcard", front: "Ömer Bedrettin Uşaklı — Kodlama ve en önemli eseri", back: "Kodlama: Bedo → Sarhoş Bedo → Deniz Sarhoşları\nEn çok sorulan eseri: Deniz Sarhoşları (Anadolu şairinin deniz temalı eseri)\nDiğer eserleri: Yayla Dumanı, Sarıkız Mermerleri", difficulty: 2, source: "yıldızlı", tags: ["cumhuriyet","milli şiir","kodlama"] },
  { id: "ex002", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "flashcard", front: "Zeki Ömer Defne — Kodlama ve en önemli eseri", back: "Kodlama: Hırsızlar zeki olur → Denizden Çalınmış Ülke\nDiğer eserleri: Sessiz Nehir, Kardelenler", difficulty: 2, source: "yıldızlı", tags: ["cumhuriyet","kodlama"] },
  { id: "ex003", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "flashcard", front: "Behçet Kemal Çağlar — Mahlası ve önemli bilgiler", back: "Mahlası: Ankaralı Aşık Ömer\nFaruk Nafiz Çamlıbel ile birlikte 'Onuncu Yıl Marşı'nı yazdı\nÖnemli eserleri: Erciyes'ten Kopan Çığ (şiir), Ergenekon (manzum tiyatro — Atatürk'ün ilgisini çekti)\nDiğer tiyatroları: Çoban, Attila", difficulty: 2, source: "yıldızlı", tags: ["cumhuriyet","10.yıl marşı"] },
  { id: "ex004", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "flashcard", front: "Bedri Rahmi Eyüboğlu — Sınavda en çok sorulan eserleri", back: "En çok sorulan şiiri: Karadut (ünlü aşk şiiri)\nDiğer şiirleri: Dol Karabakır Dol (tüm şiirleri), Yaradan'a Mektuplar, Tuz\nGezi/Deneme: Canım Anadolu, Tezek, Delifişek, Resme Başlarken", difficulty: 1, source: "yıldızlı", tags: ["cumhuriyet","karadut"] },
  { id: "ex005", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "flashcard", front: "Ahmet Kutsi Tecer — En önemli rolü ve eserleri", back: "En önemli rolü: Aşık Veysel'i keşfedip Türk edebiyatına tanıtan kişidir\nAyrıca Yunus Emre ve Karacaoğlan üzerine araştırmalar yaptı\nTiyatro: Köşebaşı (orta oyunu teknikleri, 24 saatlik zaman dilimi — çok önemli!), Koçyiğit Köroğlu, Yazılan Bozulmaz\nŞiirleri: Neredesin, Orada Bir Köy Var Uzakta", difficulty: 1, source: "yıldızlı", tags: ["cumhuriyet","aşık veysel"] },
  { id: "ex006", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "flashcard", front: "Arif Nihat Asya — En ünlü şiir kitabı ve önemi", back: "En ünlü şiir kitabı: Heykeltıraş (sınavda özellikle sorulur)\nDiğer kitapları: Bir Bayrak Rüzgar Bekliyor, Dualar ve Aminler, Kökler ve Dallar\nCumhuriyet döneminin en büyük RUBAİ yazarıdır (Rübayat-ı Arif, Kıbrıs Rubaileri)", difficulty: 1, source: "yıldızlı", tags: ["cumhuriyet","rubai"] },
  { id: "ex007", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "flashcard", front: "Orhan Şaik Gökyay — Önemli eserleri", back: "En ünlü şiiri: Bu Vatan Kimin?\nEn ünlü incelemesi: Destursuz Bağa Girenler (Divan edebiyatı araştırmalarındaki yanlışlıkları eleştiren sert başyapıt)", difficulty: 2, source: "yıldızlı", tags: ["cumhuriyet","eleştiri"] },
  { id: "ex008", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "flashcard", front: "Mithat Cemal Kuntay — Önemli eserleri", back: "Şiir: Türkün Şehnamesi ('Bayrakları bayrak yapan üstündeki kandır...' buradadır)\nRoman: Üç İstanbul (Adnan karakteri, 3 dönem: Abdülhamid + Meşrutiyet + Mütareke)", difficulty: 2, source: "yıldızlı", tags: ["cumhuriyet","üç istanbul"] },
  { id: "ex009", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "flashcard", front: "Necmettin Halil Onan — Önemli eserleri", back: "En ünlü şiiri: Bir Yolcuya ('Dur Yolcu!' diye başlar)\nŞiir kitapları: Bir Yudum Daha, Çakıl Taşları", difficulty: 2, source: "yıldızlı", tags: ["cumhuriyet","dur yolcu"] },

  // Saf Şiir
  { id: "ex010", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Saf Şiir", type: "flashcard", front: "Cahit Sıtkı Tarancı — Saf Şiir bağlamında önemli bilgiler", back: "Ziya'ya Mektuplar: Yedi Meşaleci dostu Ziya Osman Saba'ya yazdığı mektuplar; kendi saf şiir estetiğini anlatır\nKilit dize: 'Her mihnet kabulüm, yeter ki gün eksilmesin penceremden.'", difficulty: 2, source: "yıldızlı", tags: ["cumhuriyet","saf şiir","ziya'ya mektuplar"] },
  { id: "ex011", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Saf Şiir", type: "flashcard", front: "Ahmet Muhip Dıranas — Ezberlenecek şiirleri", back: "Olvido, Serenad, Fahriye Abla (sınavda en çok sorulan üç şiiri)", difficulty: 1, source: "yıldızlı", tags: ["cumhuriyet","saf şiir","dıranas"] },
  { id: "ex012", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Saf Şiir", type: "flashcard", front: "SAF ŞİİR ≠ SADE ŞİİR — Sınav Tuzağı!", back: "TUZAK: Saf şiir, dilin sadeliğiyle alakalı DEĞİLDİR!\nSaf şiir = ideolojiden uzak, ahenk ve estetik odaklı KAPALI şiir anlayışı\nSınavda 'sade şiir' seçeneği çeldirici olarak kullanılır — DÜŞMEYİN!", difficulty: 1, source: "yıldızlı", tags: ["cumhuriyet","saf şiir","tuzak"] },

  // Çağdaş Türk Dünyası
  { id: "ex013", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Çağdaş Türk Dünyası", type: "flashcard", front: "Cengiz Aytmatov (Kırgızistan) — Önemli eserleri", back: "Cemile: Fransız yazar Aragon tarafından 'dünyanın en güzel aşk hikayesi' seçildi\nGün Olur Asra Bedel / Gün Uzar Yüzyıl Olur: 'Mankurtlaştırma' temasını dünya edebiyatına kazandırdı\nDiğerleri: Toprak Ana, Selvi Boylum Al Yazmalım, Elveda Gülsarı, Beyaz Gemi", difficulty: 1, source: "yıldızlı", tags: ["türk dünyası","kırgızistan","mankurt"] },
  { id: "ex014", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Çağdaş Türk Dünyası", type: "flashcard", front: "Cengiz Dağcı (Kırım) — Önemli eserleri", back: "Korkunç Yıllar / Ölüm ve Korku Günleri\nOnlar da İnsandı\nO Topraklar Bizimdi\nDönüş\nBadem Dalına Asılı Bebeler (Kırım Türklerinin zulmünü anlatır)", difficulty: 2, source: "yıldızlı", tags: ["türk dünyası","kırım"] },
  { id: "ex015", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Çağdaş Türk Dünyası", type: "flashcard", front: "İsmail Gaspıralı (Kırım) — Sloganı ve yayın organı", back: "Slogan: 'Dilde, fikirde, işte birlik!'\nYayın organı: Tercüman Gazetesi\nLakabı: Kırım Türklerinin Şahı", difficulty: 1, source: "yıldızlı", tags: ["türk dünyası","kırım","gaspıralı"] },
  { id: "ex016", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Çağdaş Türk Dünyası", type: "flashcard", front: "Şehriyar (Azerbaycan) — Ezberlenecek şiiri", back: "Heyder Babaya Selam: Türk dünyasında en çok bilinen hasret ve vatan şiiridir", difficulty: 1, source: "yıldızlı", tags: ["türk dünyası","azerbaycan"] },
  { id: "ex017", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Çağdaş Türk Dünyası", type: "flashcard", front: "Bahtiyar Vahapzade (Azerbaycan) — Önemli eserleri", back: "Şiir: Benim Dostlarım\nTiyatro: Feryat", difficulty: 2, source: "yıldızlı", tags: ["türk dünyası","azerbaycan"] },
  { id: "ex018", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Çağdaş Türk Dünyası", type: "flashcard", front: "Ata Terzibaşı (Irak/Kerkük) — Kilit bilgi", back: "'Kerkük denilince akla ilk o gelmelidir'\nEn ünlü eserleri: Kerkük Hoyrat ve Manileri, Kerkük Şairleri", difficulty: 2, source: "yıldızlı", tags: ["türk dünyası","kerkük"] },
  { id: "ex019", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Çağdaş Türk Dünyası", type: "flashcard", front: "Osman Türkay (Kıbrıs) — Kilit bilgi", back: "Dünyada en çok mektup alan Türk edebiyatçısı unvanına sahiptir", difficulty: 2, source: "yıldızlı", tags: ["türk dünyası","kıbrıs"] },
  { id: "ex020", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Çağdaş Türk Dünyası", type: "flashcard", front: "Özker Yaşın (Kıbrıs) — Kilit bilgi", back: "Kıbrıs Savaşı'nı eserlerinde en başarılı şekilde işleyen yazardır", difficulty: 2, source: "yıldızlı", tags: ["türk dünyası","kıbrıs"] },

  // Mavi Anadolu Tuzağı
  { id: "ex021", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Sınav Tuzakları", type: "flashcard", front: "MAVİ ANADOLU / MAVİ SÜRGÜN TUZAĞI — KARIŞTİRMA!", back: "Mavi Anadolu + Mavi Yolculuk → AZRA ERHAT'a aittir (+ İlyada, Odysseia çevirileri)\nMavi Sürgün (otobiyografik) → HALİKARNAS BALIKÇISI'na (Cevat Şakir Kabaağaçlı) aittir\n⚠️ ÖSYM bu isim benzerliğini çeldirici olarak çok kullanır!", difficulty: 1, source: "yıldızlı", tags: ["tuzak","mavi anadolu","azra erhat","halikarnas balıkçısı"] },

  // Sınav Odaklı Quiz Soruları
  { id: "eq001", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "quiz", question: "'Deniz Sarhoşları' adlı şiir kitabı hangi şaire aittir?", options: ["Ömer Bedrettin Uşaklı", "Zeki Ömer Defne", "Behçet Kemal Çağlar", "Arif Nihat Asya"], answer: "Ömer Bedrettin Uşaklı", difficulty: 1, source: "yıldızlı", tags: ["cumhuriyet","milli şiir"] },
  { id: "eq002", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "quiz", question: "'Denizden Çalınmış Ülke' adlı eser hangi şaire aittir?", options: ["Zeki Ömer Defne", "Ömer Bedrettin Uşaklı", "Arif Nihat Asya", "Orhan Şaik Gökyay"], answer: "Zeki Ömer Defne", difficulty: 1, source: "yıldızlı", tags: ["cumhuriyet","milli şiir"] },
  { id: "eq003", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "quiz", question: "'Onuncu Yıl Marşı' birlikte kimler tarafından yazılmıştır?", options: ["Faruk Nafiz Çamlıbel ve Behçet Kemal Çağlar", "Arif Nihat Asya ve Orhan Şaik Gökyay", "Bedri Rahmi Eyüboğlu ve Ahmet Kutsi Tecer", "Zeki Ömer Defne ve Mithat Cemal Kuntay"], answer: "Faruk Nafiz Çamlıbel ve Behçet Kemal Çağlar", difficulty: 1, source: "yıldızlı", tags: ["cumhuriyet","10.yıl marşı"] },
  { id: "eq004", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "quiz", question: "Sınavda en çok sorulan, Bedri Rahmi Eyüboğlu'nun ünlü aşk şiiri hangisidir?", options: ["Karadut", "Dol Karabakır Dol", "Yaradan'a Mektuplar", "Tuz"], answer: "Karadut", difficulty: 1, source: "yıldızlı", tags: ["cumhuriyet","bedri rahmi"] },
  { id: "eq005", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "quiz", question: "Aşık Veysel'i Türk edebiyatına tanıtan kişi kimdir?", options: ["Ahmet Kutsi Tecer", "Bedri Rahmi Eyüboğlu", "Behçet Kemal Çağlar", "Arif Nihat Asya"], answer: "Ahmet Kutsi Tecer", difficulty: 1, source: "yıldızlı", tags: ["cumhuriyet","aşık veysel"] },
  { id: "eq006", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "quiz", question: "Orta oyunu teknikleriyle yazılmış, ailesini terk eden bir adamın mahallesine dönüşünü 24 saatlik zaman diliminde anlatan tiyatro eseri hangisidir?", options: ["Köşebaşı", "Koçyiğit Köroğlu", "Yazılan Bozulmaz", "Ergenekon"], answer: "Köşebaşı", difficulty: 2, source: "yıldızlı", tags: ["cumhuriyet","tiyatro","ahmet kutsi tecer"] },
  { id: "eq007", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "quiz", question: "Arif Nihat Asya'nın sınavda özellikle vurgulanan en ünlü şiir kitabı hangisidir?", options: ["Heykeltıraş", "Bir Bayrak Rüzgar Bekliyor", "Dualar ve Aminler", "Kökler ve Dallar"], answer: "Heykeltıraş", difficulty: 2, source: "yıldızlı", tags: ["cumhuriyet","arif nihat asya"] },
  { id: "eq008", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "quiz", question: "'Bu Vatan Kimin?' şiiri ve 'Destursuz Bağa Girenler' incelemesi hangi şaire aittir?", options: ["Orhan Şaik Gökyay", "Arif Nihat Asya", "Mithat Cemal Kuntay", "Necmettin Halil Onan"], answer: "Orhan Şaik Gökyay", difficulty: 2, source: "yıldızlı", tags: ["cumhuriyet","eleştiri"] },
  { id: "eq009", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "quiz", question: "'Bayrakları bayrak yapan üstündeki kandır...' dizesi hangi eserde yer alır?", options: ["Türkün Şehnamesi", "Heykeltıraş", "Erciyes'ten Kopan Çığ", "Bir Bayrak Rüzgar Bekliyor"], answer: "Türkün Şehnamesi", difficulty: 1, source: "yıldızlı", tags: ["cumhuriyet","mithat cemal kuntay"] },
  { id: "eq010", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Milli Edebiyat Şiiri", type: "quiz", question: "'Dur Yolcu!' diye başlayan meşhur şiirin adı ve şairi hangisidir?", options: ["Bir Yolcuya — Necmettin Halil Onan", "Bu Vatan Kimin — Orhan Şaik Gökyay", "Karadut — Bedri Rahmi Eyüboğlu", "Heyder Babaya Selam — Şehriyar"], answer: "Bir Yolcuya — Necmettin Halil Onan", difficulty: 1, source: "yıldızlı", tags: ["cumhuriyet","dur yolcu"] },
  { id: "eq011", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Saf Şiir", type: "quiz", question: "Saf şiir anlayışı hakkında aşağıdakilerden hangisi YANLIŞTIR?", options: ["Sade ve anlaşılır bir dil kullanımını esas alır", "İdeolojik ve siyasi içerikten uzak durur", "Ahenk, ritim ve estetik ön plandadır", "Kapalı ve çağrışım gücü yüksek bir dil kullanır"], answer: "Sade ve anlaşılır bir dil kullanımını esas alır", difficulty: 2, source: "yıldızlı", tags: ["cumhuriyet","saf şiir","tuzak"] },
  { id: "eq012", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Saf Şiir", type: "quiz", question: "Cahit Sıtkı Tarancı'nın Yedi Meşaleci dostu Ziya Osman Saba'ya yazdığı, kendi şiir estetiğini anlattığı eser hangisidir?", options: ["Ziya'ya Mektuplar", "Otuz Beş Yaş", "Ömrümde Sükut", "Düşten Güzel"], answer: "Ziya'ya Mektuplar", difficulty: 2, source: "yıldızlı", tags: ["cumhuriyet","saf şiir","cahit sıtkı"] },
  { id: "eq013", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Saf Şiir", type: "quiz", question: "'Olvido', 'Serenad' ve 'Fahriye Abla' şiirlerinin ortak şairi kimdir?", options: ["Ahmet Muhip Dıranas", "Cahit Sıtkı Tarancı", "Behçet Necatigil", "Asaf Halet Çelebi"], answer: "Ahmet Muhip Dıranas", difficulty: 1, source: "yıldızlı", tags: ["cumhuriyet","saf şiir","dıranas"] },
  { id: "eq014", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Çağdaş Türk Dünyası", type: "quiz", question: "Fransız yazar Aragon tarafından 'dünyanın en güzel aşk hikayesi' olarak nitelendirilen eser hangisidir?", options: ["Cemile — Cengiz Aytmatov", "Gün Olur Asra Bedel — Cengiz Aytmatov", "Selvi Boylum Al Yazmalım — Cengiz Aytmatov", "O Topraklar Bizimdi — Cengiz Dağcı"], answer: "Cemile — Cengiz Aytmatov", difficulty: 1, source: "yıldızlı", tags: ["türk dünyası","aytmatov"] },
  { id: "eq015", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Çağdaş Türk Dünyası", type: "quiz", question: "'Mankurtlaştırma' temasını dünya edebiyatına kazandıran eser ve yazarı hangisidir?", options: ["Gün Olur Asra Bedel — Cengiz Aytmatov", "Cemile — Cengiz Aytmatov", "Korkunç Yıllar — Cengiz Dağcı", "O Topraklar Bizimdi — Cengiz Dağcı"], answer: "Gün Olur Asra Bedel — Cengiz Aytmatov", difficulty: 1, source: "yıldızlı", tags: ["türk dünyası","mankurt"] },
  { id: "eq016", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Çağdaş Türk Dünyası", type: "quiz", question: "'Dilde, fikirde, işte birlik!' sloganı ve Tercüman Gazetesi hangi isimle özdeşleşir?", options: ["İsmail Gaspıralı", "Cengiz Dağcı", "Osman Akçokraklı", "Ata Terzibaşı"], answer: "İsmail Gaspıralı", difficulty: 1, source: "yıldızlı", tags: ["türk dünyası","gaspıralı"] },
  { id: "eq017", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Çağdaş Türk Dünyası", type: "quiz", question: "Türk dünyasında en çok bilinen hasret ve vatan şiiri olan 'Heyder Babaya Selam' hangi şaire aittir?", options: ["Şehriyar", "Bahtiyar Vahapzade", "Osman Türkay", "Özker Yaşın"], answer: "Şehriyar", difficulty: 1, source: "yıldızlı", tags: ["türk dünyası","azerbaycan"] },
  { id: "eq018", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Sınav Tuzakları", type: "quiz", question: "Aşağıdakilerden hangisi AZRA ERHAT'a ait bir eserdir?", options: ["Mavi Anadolu", "Mavi Sürgün", "Ölü Deniz", "Mavi Yolculuk ve Mavi Sürgün"], answer: "Mavi Anadolu", difficulty: 2, source: "yıldızlı", tags: ["tuzak","azra erhat"] },
  { id: "eq019", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Sınav Tuzakları", type: "quiz", question: "'Mavi Sürgün' adlı otobiyografik eser kime aittir?", options: ["Halikarnas Balıkçısı (Cevat Şakir Kabaağaçlı)", "Azra Erhat", "Attila İlhan", "Melih Cevdet Anday"], answer: "Halikarnas Balıkçısı (Cevat Şakir Kabaağaçlı)", difficulty: 1, source: "yıldızlı", tags: ["tuzak","halikarnas balıkçısı"] },
  { id: "eq020", mode: "exam" as const, subject: "Edebiyat", topic: "Cumhuriyet Dönemi", subtopic: "Çağdaş Türk Dünyası", type: "quiz", question: "Behçet Kemal Çağlar şiirlerinde hangi mahlası kullanmıştır?", options: ["Ankaralı Aşık Ömer", "Çamlıbel", "Kirpi", "Bozkırlı"], answer: "Ankaralı Aşık Ömer", difficulty: 2, source: "yıldızlı", tags: ["cumhuriyet","mahlas"] },
];
